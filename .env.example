# 배포 시 설정할 환경변수 (Render > Environment 에 입력)

# 로그인 비밀번호 (봉사자들에게 공유)
APP_PASSWORD=dog0616

# 세션 암호화 키 (길고 무작위인 문자열. Render에서 자동 생성 가능)
SESSION_SECRET=길고_무작위인_비밀키

# Turso 데이터베이스 (https://turso.tech 에서 발급)
TURSO_DATABASE_URL=libsql://your-db-xxxx.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOi...토큰...

# 로컬에서 개발할 땐 위 TURSO 값 없이 .env 에 APP_PASSWORD 만 있어도 됩니다.
# (TURSO 값이 없으면 data/meongbapcha.db 로컬 파일을 사용)
